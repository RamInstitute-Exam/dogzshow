generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================
// USER & ROLE MANAGEMENT
// ==============================

model User {
  id         String  @id @default(uuid())
  title      String? // Mr / Mrs / Ms / Dr
  email      String  @unique
  password   String
  firstName  String?
  lastName   String?
  phone      String? // Mobile Number
  altPhone   String?
  dob        DateTime?
  gender     String?
  avatarUrl  String?
  
  // Address Information
  doorNo     String?
  buildingName String?
  street     String?
  landmark   String?
  address1   String?
  address2   String?
  city       String?
  state      String?
  country    String?
  pincode    String?

  // Profile Information
  occupation   String?
  organization String?
  website      String?

  // KCI Information
  kciMembershipNo      String?
  breederLicenseNo     String?
  kennelClubName       String?
  experienceInDogShows String?

  // Preferences & Terms
  prefSms        Boolean @default(true)
  prefEmail      Boolean @default(true)
  prefWhatsapp   Boolean @default(true)
  termsAccepted  Boolean @default(false)
  privacyAccepted Boolean @default(false)
  
  mobileVerified Boolean @default(false)

  provider   String? // 'local', 'google', 'facebook'
  providerId String?
  isActive   Boolean @default(true)

  roles              UserRole[]
  dogsOwned          Dog[]               @relation("DogOwner")
  eventRegistrations EventRegistration[]
  payments           Payment[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  supportTickets     SupportTicket[]     @relation("UserTickets")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // Super Admin, Admin, Sub Admin, Judge, User, Public Visitor
  description String?
  displayName String?
  color       String?  @default("#3B82F6")
  icon        String?  @default("shield")
  priority    Int      @default(0)
  status      String   @default("ACTIVE")

  users       UserRole[]
  permissions RolePermission[]
  menuPermissions MenuPermission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique // e.g., 'manage_events', 'manage_users'
  description String?

  roles RolePermission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model OtpVerification {
  id           String   @id @default(uuid())
  phone        String   @unique
  otpCode      String
  otpExpiry    DateTime
  otpAttempts  Int      @default(0)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==============================
// DOG MANAGEMENT
// ==============================

model FCIGroup {
  id             String  @id @default(uuid())
  groupNumber    Int     @unique // 1 to 10
  name           String
  slug           String  @unique @default(cuid())
  description    String? @db.Text
  heroImage      String?
  cardImage      String?
  icon           String?
  displayOrder   Int     @default(0)
  seoTitle       String?
  seoDescription String? @db.Text
  featured       Boolean @default(false)
  status         String  @default("ACTIVE")

  breeds Breed[]
  events EventFCIGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Breed {
  id         String    @id @default(uuid())
  name       String    @unique
  fciGroupId String?
  fciGroup   FCIGroup? @relation(fields: [fciGroupId], references: [id])

  dogs Dog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgeClass {
  id          String   @id @default(uuid())
  name        String   @unique // Minor Puppy, Puppy, Junior, etc.
  description String?
  minMonths   Int?     // Minimum age in months (inclusive)
  maxMonths   Int?     // Maximum age in months (inclusive)
  specialRequirements String? // e.g. "Champion Only", "Breed In India"
  status      String   @default("ACTIVE")
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Breeder {
  id          String  @id @default(uuid())
  name        String
  kennelName  String?
  country     String?
  address     String?
  phone       String?
  contactInfo String?

  dogs Dog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Owner {
  id          String  @id @default(uuid())
  name        String
  fatherName  String?
  email       String?
  phone       String?
  whatsapp    String?
  address     String?
  state       String?
  district    String?
  city        String?
  pincode     String?
  contactInfo String?

  dogs Dog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dog {
  id              String    @id @default(uuid())
  name            String
  breedId         String
  breed           Breed     @relation(fields: [breedId], references: [id])
  gender          String // MALE, FEMALE
  dob             DateTime?
  color           String?
  markings        String?
  weight          Float?
  height          Float?
  kciNumber       String?   @unique
  microchipNumber String?   @unique
  micNumber       String?   @unique
  isImported      Boolean   @default(false)
  countryOfOrigin String?
  isChampion      Boolean   @default(false)
  
  bloodline       Json?     // { sire, dam, grandSire, grandDam, notes }
  medical         Json?     // { vaccinationStatus, vetName, healthCertUrl, notes }

  pedigreeUrl         String?
  certificateFrontUrl String?
  certificateBackUrl  String?

  ownerId     String?
  userOwnerId String // The platform user who registered the dog
  breederId   String?

  ownerUser User     @relation("DogOwner", fields: [userOwnerId], references: [id])
  owner     Owner?   @relation(fields: [ownerId], references: [id])
  breeder   Breeder? @relation(fields: [breederId], references: [id])

  photos         DogPhoto[]
  documents      DogDocument[]
  kciCertificate KCICertificate?
  registrations  EventRegistration[]
  matches        CompetitionMatch[]
  winnerTags     WinnerTag[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userOwnerId])
  @@index([createdAt])
}

model DogPhoto {
  id        String  @id @default(uuid())
  dogId     String
  dog       Dog     @relation(fields: [dogId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
}

model DogDocument {
  id    String @id @default(uuid())
  dogId String
  dog   Dog    @relation(fields: [dogId], references: [id], onDelete: Cascade)
  type  String // e.g., 'HEALTH_CERT'
  url   String

  createdAt DateTime @default(now())
}

model KCICertificate {
  id            String @id @default(uuid())
  dogId         String @unique
  dog           Dog    @relation(fields: [dogId], references: [id], onDelete: Cascade)
  url           String
  ocrConfidence Float?
  extractedData Json?
  status        String @default("PENDING") // PENDING, APPROVED, REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// EVENT & COMPETITION MANAGEMENT
// ==============================

model Club {
  id                 String   @id @default(uuid())
  name               String
  logoUrl            String?
  address            String?
  city               String?
  state              String?
  country            String?
  secretary          String?
  president          String?
  email              String?  @unique
  phone              String?
  website            String?
  facebook           String?
  instagram          String?
  description        String?  @db.Text
  history            String?  @db.Text
  registrationNumber String?
  isFeatured         Boolean  @default(false)
  isActive           Boolean  @default(true)
  
  slug               String?  @unique
  seoTitle           String?
  seoDescription     String?  @db.Text
  
  events      Event[]

  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id                      String    @id @default(uuid())
  slug                    String    @unique @default(cuid())
  clubId                  String
  club                    Club      @relation(fields: [clubId], references: [id])
  name                    String
  subtitle                String?
  description             String?   @db.Text
  type                    String // FCI, CACIB
  fciBadge                String?
  startDate               DateTime
  endDate                 DateTime
  venue                   String
  entryFee                Float
  prizePool               String?
  bannerUrl               String?
  capacity                Int?
  availableSlots          Int?
  status                  String    @default("DRAFT") // DRAFT, REGISTRATION_OPEN, ONGOING, COMPLETED
  registrationWindowStart DateTime?
  registrationWindowEnd   DateTime?
  
  // UI Display & Management
  cardImage               String?
  mobileBanner            String?
  featuredImage           String?
  judgesCount             Int?
  ctaText                 String?
  ctaLink                 String?
  displayOrder            Int       @default(0)
  isFeatured              Boolean   @default(false)
  
  // JSON UI Data
  timeline                Json?     // Array of { time, title, description }
  competitionRules        Json?     // Array of string rules
  downloads               Json?     // Array of { title, url }
  faqs                    Json?     // Array of { question, answer }
  
  // SEO
  seoTitle                String?
  seoDescription          String?   @db.Text
  metaKeywords            String?
  ogImage                 String?

  fciGroups        EventFCIGroup[]
  categories       EventCategory[]
  registrations    EventRegistration[]
  judgeAssignments JudgeAssignment[]
  rounds           CompetitionRound[]
  mediaGallery     EventGallery[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model EventFCIGroup {
  eventId    String
  fciGroupId String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fciGroup   FCIGroup @relation(fields: [fciGroupId], references: [id], onDelete: Cascade)

  @@id([eventId, fciGroupId])
}

model EventCategory {
  id          String  @id @default(uuid())
  eventId     String
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String // e.g., 'Junior', 'Open', 'Champion'
  description String?

  registrations EventRegistration[]

  createdAt DateTime @default(now())
}

model Judge {
  id             String  @id @default(uuid())
  name           String
  email          String? @unique
  phone          String?
  gender         String?
  dob            String?
  address        String?
  city           String?
  state          String?
  country        String?
  experience     String?
  specialization String?
  registrationNumber String?
  certifications String?
  qualifications String? @db.Text
  groups         String? // e.g. "Groups 1, 2, 8"
  bio            String? @db.Text
  photoUrl       String?
  credentials    String? @db.Text
  socialLinks    Json?
  sortOrder      Int     @default(0)
  isFeatured     Boolean @default(false)
  status         String  @default("ACTIVE") // ACTIVE, INACTIVE

  slug           String? @unique
  seoTitle       String?
  seoDescription String? @db.Text

  assignments JudgeAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model JudgeAssignment {
  id             String @id @default(uuid())
  eventId        String
  judgeId        String
  assignedGroups Json? // List of FCI Group IDs they are judging

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  judge Judge @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model EventRegistration {
  id           String @id @default(uuid())
  serialNumber String @unique // e.g., JZ-2026-001-0001
  eventId      String
  userId       String
  dogId        String
  categoryId   String
  status       String @default("PENDING") // PENDING, CONFIRMED, CANCELLED

  event    Event         @relation(fields: [eventId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  dog      Dog           @relation(fields: [dogId], references: [id])
  category EventCategory @relation(fields: [categoryId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, dogId])
  @@index([userId])
  @@index([dogId])
  @@index([status])
  @@index([createdAt])
}

model CompetitionRound {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String // Round 1, Round 2, Best In Show
  level   Int // 1, 2, 3
  status  String @default("PENDING") // PENDING, ACTIVE, COMPLETED

  matches CompetitionMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitionMatch {
  id      String           @id @default(uuid())
  roundId String
  round   CompetitionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  dogId   String
  dog     Dog              @relation(fields: [dogId], references: [id])
  status  String           @default("PARTICIPATING") // PARTICIPATING, ELIMINATED, ADVANCED
  score   Float?
  notes   String?

  winners Winner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Winner {
  id             String           @id @default(uuid())
  matchId        String
  match          CompetitionMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  awardTitle     String // Best of Breed, Best of Group, Best in Show
  rank           Int?
  
  ownerName      String?
  breedName      String?
  competition    String?
  year           Int?
  certificateUrl String?
  imageUrl       String?
  videoUrl       String?
  description    String?          @db.Text

  winnerTag WinnerTag?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model WinnerTag {
  id        String   @id @default(uuid())
  winnerId  String   @unique
  winner    Winner   @relation(fields: [winnerId], references: [id], onDelete: Cascade)
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  award     String
  eventName String
  eventDate DateTime
  badgeUrl  String?

  createdAt DateTime @default(now())
}

// ==============================
// PAYMENTS
// ==============================

model Payment {
  id             String            @id @default(uuid())
  registrationId String            @unique
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  amount         Float
  currency       String            @default("INR")
  status         String            @default("PENDING") // PENDING, SUCCESS, FAILURE, REFUNDED
  transactionId  String?           @unique
  paymentGateway String // RAZORPAY, STRIPE

  logs    PaymentLog[]
  refunds Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PaymentLog {
  id              String  @id @default(uuid())
  paymentId       String
  payment         Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  status          String
  responsePayload Json?

  createdAt DateTime @default(now())
}

model Refund {
  id            String  @id @default(uuid())
  paymentId     String
  payment       Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount        Float
  status        String  @default("PENDING") // PENDING, PROCESSED, FAILED
  refundReason  String?
  transactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// ENTERPRISE NOTIFICATION SYSTEM
// ==============================

model Notification {
  id                String    @id @default(uuid())
  title             String
  message           String    @db.Text
  shortMessage      String?   @db.Text
  notificationType  String    // IN_APP, EMAIL, SMS, WHATSAPP, PUSH, BROADCAST
  category          String    // SYSTEM, EVENT, PAYMENT, COMPETITION, SUPPORT
  priority          String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  
  senderId          String?
  receiverId        String
  receiverRole      String?
  
  eventId           String?
  dogId             String?
  paymentId         String?
  competitionId     String?
  
  actionUrl         String?
  icon              String?
  image             String?
  
  isRead            Boolean   @default(false)
  readAt            DateTime?
  isArchived        Boolean   @default(false)
  
  deliveryStatus    String    @default("PENDING") // PENDING, DELIVERED, FAILED
  emailStatus       String?
  smsStatus         String?
  whatsappStatus    String?
  pushStatus        String?
  
  expiresAt         DateTime?
  
  user              User      @relation(fields: [receiverId], references: [id], onDelete: Cascade)
  logs              NotificationLog[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationTemplate {
  id               String   @id @default(uuid())
  name             String   @unique
  category         String
  subject          String?
  emailTemplate    String?  @db.Text
  smsTemplate      String?  @db.Text
  whatsappTemplate String?  @db.Text
  pushTemplate     String?  @db.Text
  variables        Json?
  status           String   @default("ACTIVE")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NotificationLog {
  id                  String       @id @default(uuid())
  notificationId      String
  notification        Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel             String       // EMAIL, SMS, WHATSAPP, PUSH
  response            Json?
  status              String       // SENT, FAILED, DELIVERED
  provider            String?      // MSG91, WATI, FIREBASE, SMTP
  providerMessageId   String?
  retryCount          Int          @default(0)

  createdAt           DateTime     @default(now())
}

model MediaGallery {
  id         String   @id @default(uuid())
  url        String
  type       String   // PHOTO, VIDEO
  category   String   // DOG_SHOW, PICS, POSTERS
  isPublic   Boolean  @default(true)
  altText    String?
  tags       Json?    // MySQL json array
  sortOrder  Int      @default(0)
  featured   Boolean  @default(false)

  createdAt  DateTime @default(now())
}

model MediaCategory {
  id     String @id @default(uuid())
  name   String
  slug   String @unique
  status String @default("ACTIVE")

  albums MediaAlbum[]
  images MediaImage[]
  videos MediaVideo[]

  @@map("media_categories")
}

model MediaAlbum {
  id         String  @id @default(uuid())
  categoryId String? @map("category_id")
  title      String
  slug       String  @unique
  coverImage String? @map("cover_image")
  status     String  @default("ACTIVE")

  category MediaCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images   MediaImage[]
  videos   MediaVideo[]

  @@index([categoryId])
  @@map("media_albums")
}

model MediaImage {
  id           String   @id @default(uuid())
  albumId      String?  @map("album_id")
  categoryId   String   @map("category_id")
  title        String
  slug         String   @unique
  description  String?  @db.Text
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  altText      String?  @map("alt_text")
  featured     Boolean  @default(false)
  views        Int      @default(0)
  likes        Int      @default(0)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")

  album    MediaAlbum?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  category MediaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([featured])
  @@index([status])
  @@index([createdAt])
  @@index([categoryId])
  @@index([albumId])
  @@map("media_images")
}

model MediaVideo {
  id           String   @id @default(uuid())
  albumId      String?  @map("album_id")
  categoryId   String   @map("category_id")
  title        String
  slug         String   @unique
  description  String?  @db.Text
  thumbnailUrl String?  @map("thumbnail_url")
  videoUrl     String   @map("video_url")
  duration     String?
  views        Int      @default(0)
  likes        Int      @default(0)
  featured     Boolean  @default(false)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")

  album    MediaAlbum?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  category MediaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([featured])
  @@index([status])
  @@index([createdAt])
  @@index([categoryId])
  @@index([albumId])
  @@map("media_videos")
}

model EventGallery {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url     String
  type    String // PHOTO, VIDEO

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String // EVENT, DOG, PAYMENT, etc.
  entityId  String?
  details   Json?
  ipAddress String?
  browser   String?
  device    String?
  oldValue  Json?
  newValue  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  description String?

  createdAt DateTime @default(now())
}

// ==============================
// SYSTEM & SETTINGS
// ==============================

model Setting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?

  updatedAt DateTime @updatedAt
}

model SerialGenerator {
  id           String @id @default(uuid())
  prefix       String @unique // e.g., 'JZ-2026-001'
  currentValue Int    @default(0)

  updatedAt DateTime @updatedAt
}

model DashboardMetric {
  id               String   @id @default(uuid())
  metricKey        String   @unique
  metricValue      Float
  lastCalculatedAt DateTime @default(now())
}

// ==============================
// CMS & MARKETING
// ==============================

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  content   String   @db.Text
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id               String   @id @default(uuid())
  title            String
  subtitle         String?
  description      String?  @db.Text
  imageUrl         String
  videoUrl         String?
  primaryBtnText   String?
  primaryBtnLink   String?
  secondaryBtnText String?
  secondaryBtnLink String?
  badgeText        String?
  overlayColor     String?
  page             String   @default("HOME")
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  isScheduled      Boolean  @default(false)
  publishAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
}

model PageBanner {
  id               String   @id @default(uuid())
  pageSlug         String   @unique
  title            String
  subtitle         String?  @db.Text
  bannerImage      String
  breadcrumbTitle  String?
  isActive         Boolean  @default(true)
  displayOrder     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("page_banners")
}

model HomepageBanner {
  id           String    @id @default(uuid())
  title        String
  desktopImage String
  mobileImage  String?
  redirectUrl  String?
  targetBlank  Boolean   @default(false)
  sortOrder    Int       @default(0)
  status       String    @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("homepage_banners")
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String // EVENT_REPORT, FINANCIAL_REPORT, etc.
  generatedBy String
  fileUrl     String
  createdAt   DateTime @default(now())
}

model CmsHeader {
  id              String   @id @default(uuid())
  logoUrl         String?
  navigation      Json?    // Array of link objects
  megaMenu        Json?
  ctaButtons      Json?
  stickyHeader    Boolean  @default(true)
  transparent     Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model CmsFooter {
  id              String   @id @default(uuid())
  companyLogo     String?
  description     String?  @db.Text
  quickLinks      Json?
  services        Json?
  resources       Json?
  socialLinks     Json?
  contactDetails  Json?
  copyrightText   String?
  privacyUrl      String?
  termsUrl        String?
  updatedAt       DateTime @updatedAt
}

model CmsAbout {
  id              String   @id @default(uuid())
  heading         String?
  subHeading      String?
  description     String?  @db.Text
  imageUrl        String?
  vision          String?  @db.Text
  mission         String?  @db.Text
  values          Json?
  achievements    Json?
  statistics      Json?
  updatedAt       DateTime @updatedAt
}

model Menu {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique @default(uuid())
  url         String
  parentId    String?
  icon        String?
  position    String   @default("NAVBAR") // NAVBAR, FOOTER_MAIN, FOOTER_QUICK, SIDEBAR, ADMIN_SIDEBAR
  displayOrder Int     @default(0)
  visibility  Boolean  @default(true)
  openNewTab  Boolean  @default(false)
  megaMenu    Json?
  badge       String?
  color       String?
  onlyLoggedUser Boolean @default(false)
  onlyGuest      Boolean @default(false)
  onlyAdmin      Boolean @default(false)
  
  permissions MenuPermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuPermission {
  id           String   @id @default(uuid())
  menuId       String
  roleId       String
  permissionId String?  // Optional specific permission required

  menu         Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([menuId, roleId])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  group       String   @default("GENERAL") // GENERAL, SEO, SMTP, SMS, STORAGE
  isPublic    Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  banner        String?
  content       String   @db.Text
  author        String?
  category      String?
  tags          Json?    // Array of strings
  seoTitle      String?
  seoDescription String? @db.Text
  publishedDate DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model CmsGlobal {
  id               String   @id @default(uuid())
  title            String
  subtitle         String?  @db.Text
  description      String?  @db.Text
  image            String?
  mobileImage      String?
  buttonText       String?
  buttonLink       String?
  seoTitle         String?
  seoDescription   String?  @db.Text
  seoKeywords      String?
  status           String   @default("ACTIVE")
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cms_global")
}

model CmsPage {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  subtitle         String?  @db.Text
  description      String?  @db.Text
  image            String?
  mobileImage      String?
  buttonText       String?
  buttonLink       String?
  seoTitle         String?
  seoDescription   String?  @db.Text
  seoKeywords      String?
  status           String   @default("ACTIVE")
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cms_pages")
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation("UserTickets", fields: [userId], references: [id], onDelete: SetNull)
  subject     String
  message     String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
}

model HeroBanner {
  id           String    @id @default(uuid())
  title        String
  subtitle     String?   @db.Text
  desktopImage String    @map("desktop_image")
  mobileImage  String?   @map("mobile_image")
  buttonText   String?   @map("button_text")
  buttonLink   String?   @map("button_link")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  seoAltText   String?   @map("seo_alt_text")
  status       String?   @default("ACTIVE")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("hero_banners")
}

